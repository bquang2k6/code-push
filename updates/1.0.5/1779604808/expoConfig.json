{
  "name": "Locket Wan",
  "slug": "locket-wan",
  "version": "1.0.5",
  "orientation": "portrait",
  "icon": "./assets/images/icon.png",
  "scheme": "myapp",
  "userInterfaceStyle": "automatic",
  "newArchEnabled": true,
  "ios": {
    "bundleIdentifier": "com.wan.locket-wan",
    "supportsTablet": true,
    "infoPlist": {
      "ITSAppUsesNonExemptEncryption": false,
      "NSCameraUsageDescription": "Ứng dụng cần camera để chụp ảnh và quay video",
      "NSMicrophoneUsageDescription": "Ứng dụng không ghi âm, chỉ dùng để quay video"
    },
    "runtimeVersion": "1.0.5"
  },
  "android": {
    "package": "com.quang2k6.locketwan",
    "googleServicesFile": "./google-services.json",
    "permissions": [
      "CAMERA",
      "RECORD_AUDIO",
      "FOREGROUND_SERVICE",
      "FOREGROUND_SERVICE_DATA_SYNC",
      "WAKE_LOCK",
      "ACCESS_NETWORK_STATE",
      "android.permission.CAMERA",
      "android.permission.RECORD_AUDIO",
      "android.permission.FOREGROUND_SERVICE",
      "android.permission.FOREGROUND_SERVICE_DATA_SYNC",
      "android.permission.WAKE_LOCK",
      "android.permission.ACCESS_NETWORK_STATE"
    ],
    "adaptiveIcon": {
      "backgroundColor": "#E6F4FE",
      "foregroundImage": "./assets/images/android-icon-foreground.png",
      "backgroundImage": "./assets/images/android-icon-background.png",
      "monochromeImage": "./assets/images/android-icon-monochrome.png"
    },
    "edgeToEdgeEnabled": true,
    "predictiveBackGestureEnabled": false,
    "runtimeVersion": "1.0.5"
  },
  "web": {
    "output": "static",
    "favicon": "./assets/images/favicon.png"
  },
  "plugins": [
    "expo-router",
    [
      "expo-camera",
      {
        "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera"
      }
    ],
    "react-native-compressor",
    "expo-notifications",
    "@react-native-firebase/app",
    "@react-native-firebase/crashlytics",
    "./withBackgroundActions.js",
    "./withSSLPinning.js",
    "./withDynamicAppIconFix.js",
